    "/api/game/results": {
      "post": {
        "tags": ["Game"],
        "summary": "Submit game results",
        "description": "Submit the authenticated user's game result after a multiplayer match.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["leaderboard"],
                "properties": {
                  "leaderboard": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "userId": { "type": "integer" },
                        "username": { "type": "string" },
                        "playerNumber": { "type": "integer" },
                        "score": { "type": "integer" }
                      }
                    }
                  },
                  "gameMode": { "type": "integer", "description": "Number of players (2, 3, or 4)" },
                  "duration": { "type": "integer", "description": "Game duration in seconds" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Results saved", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" } } } } } },
          "400": { "description": "Invalid data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/leaderboard": {
      "get": {
        "tags": ["Game"],
        "summary": "Get leaderboard",
        "description": "Retrieve the top players ranked by wins, games played, or XP.",
        "security": [],
        "parameters": [
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["wins", "gamesPlayed", "xp"], "default": "wins" }, "description": "Sort field" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10, "maximum": 100 } }
        ],
        "responses": {
          "200": {
            "description": "Leaderboard",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "leaderboard": { "type": "array", "items": { "$ref": "#/components/schemas/LeaderboardEntry" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations/{id}/messages": {
      "get": {
        "tags": ["Chat"],
        "summary": "Get conversation messages",
        "description": "Retrieve up to 200 messages from a conversation. The authenticated user must be a participant.",
        "security": [{ "SessionAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Conversation ID" }
        ],
        "responses": {
