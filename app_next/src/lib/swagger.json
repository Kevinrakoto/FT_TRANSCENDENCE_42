{
  "openapi": "3.0.3",
  "info": {
    "title": "Tank Battle API",
    "description": "API for Tank Battle - a multiplayer tank game.\n\n**Authentication:**\n- **Public API**: Use `X-API-Key` header with a valid API key (generate via `POST /api/me/api-keys` with session auth).\n- **Session API**: Requires a valid NextAuth session (cookie-based).",
    "version": "1.1.0",
    "contact": {
      "name": "Tank Battle API Support"
    }
  },
  "servers": [
    {
      "url": "https://localhost:8443",
      "description": "Local development server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key generated from your profile. Format: `pk_<uuid>`. Generate keys via `POST /api/me/api-keys` (requires session auth)."
      },
      "SessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "next-auth.session-token",
        "description": "NextAuth session cookie. Obtained by signing in via the web application."
      }
    },
    "schemas": {
      "Pagination": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "example": 150 },
          "limit": { "type": "integer", "example": 10 },
          "offset": { "type": "integer", "example": 0 },
          "hasMore": { "type": "boolean", "example": true }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Invalid API key" }
        }
      },
      "ProfileSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "username": { "type": "string", "example": "TankMaster" },
          "tankLevel": { "type": "integer", "example": 12 },
          "xp": { "type": "integer", "example": 5400 },
          "wins": { "type": "integer", "example": 42 },
          "gamesPlayed": { "type": "integer", "example": 100 },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProfileDetail": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "username": { "type": "string", "example": "TankMaster" },
          "email": { "type": "string", "format": "email", "example": "tank@battle.com" },
          "tankColor": { "type": "string", "example": "#ff0000" },
          "tankLevel": { "type": "integer", "example": 12 },
          "xp": { "type": "integer", "example": 5400 },
          "wins": { "type": "integer", "example": 42 },
          "gamesPlayed": { "type": "integer", "example": 100 },
          "isOnline": { "type": "boolean", "example": true },
          "lastSeen": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "gamesAsPlayer": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GameHistory" }
          }
        }
      },
      "UserSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "username": { "type": "string", "example": "TankMaster" },
          "tankLevel": { "type": "integer", "example": 12 },
          "xp": { "type": "integer", "example": 5400 },
          "wins": { "type": "integer", "example": 42 },
          "gamesPlayed": { "type": "integer", "example": 100 },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "UserStats": {
        "type": "object",
        "properties": {
          "totalGames": { "type": "integer", "example": 100 },
          "totalWins": { "type": "integer", "example": 42 },
          "totalXp": { "type": "integer", "example": 5400 },
          "winRate": { "type": "integer", "example": 42, "description": "Win rate as percentage" },
          "recentGames": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GameHistory" }
          }
        }
      },
      "GameHistory": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "opponentId": { "type": "integer", "example": 2 },
          "winnerId": { "type": "integer", "example": 1 },
          "playerScore": { "type": "integer", "example": 10 },
          "opponentScore": { "type": "integer", "example": 7 },
          "duration": { "type": "integer", "example": 180, "description": "Duration in seconds" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Friend": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 2 },
          "username": { "type": "string", "example": "TankPro" },
          "tankLevel": { "type": "integer", "example": 8 },
          "wins": { "type": "integer", "example": 25 },
          "isOnline": { "type": "boolean", "example": true },
          "lastSeen": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "userId": { "type": "integer", "example": 1 },
          "type": { "type": "string", "example": "FRIEND_REQUEST" },
          "message": { "type": "string", "example": "TankPro sent you a friend request" },
          "isRead": { "type": "boolean", "example": false },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProfileUpdateBody": {
        "type": "object",
        "properties": {
          "tankColor": { "type": "string", "example": "#00ff00", "description": "Hex color code" }
        }
      },
      "NotificationUpdateBody": {
        "type": "object",
        "properties": {
          "markAllRead": { "type": "boolean", "example": true, "description": "Mark all notifications as read" },
          "notificationIds": {
            "type": "array",
            "items": { "type": "integer" },
            "example": [1, 2, 3],
            "description": "Specific notification IDs to mark as read"
          }
        }
      },
      "LeaderboardEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "username": { "type": "string", "example": "TankMaster" },
          "tankLevel": { "type": "integer", "example": 12 },
          "xp": { "type": "integer", "example": 5400 },
          "wins": { "type": "integer", "example": 42 },
          "gamesPlayed": { "type": "integer", "example": 100 }
        }
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "My CLI Key" },
          "key": { "type": "string", "example": "pk_abc123def456", "description": "Only returned on creation" },
          "isActive": { "type": "boolean", "example": true },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true },
          "lastUsedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "content": { "type": "string", "example": "Hello!" },
          "conversationId": { "type": "integer", "example": 1 },
          "userId": { "type": "integer", "example": 1 },
          "createdAt": { "type": "string", "format": "date-time" },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "username": { "type": "string" },
              "tankColor": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new account",
        "description": "Create a new user account with username, email, and password.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string", "example": "TankMaster" },
                  "email": { "type": "string", "format": "email", "example": "tank@battle.com" },
                  "password": { "type": "string", "minLength": 6, "example": "password123" },
                  "tankColor": { "type": "string", "example": "#00ff00", "description": "Optional hex color" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Account created successfully" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "username": { "type": "string" },
                        "email": { "type": "string" },
                        "tankColor": { "type": "string" }
                      }
                    },
                    "redirect": { "type": "string", "example": "/signin" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error or duplicate user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["Me"],
        "summary": "Get current user",
        "description": "Retrieve the authenticated user's profile.",
        "security": [{ "SessionAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "user": { "$ref": "#/components/schemas/ProfileDetail" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Me"],
        "summary": "Update current user",
        "description": "Update the authenticated user's tank color.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileUpdateBody" } } }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "user": { "$ref": "#/components/schemas/ProfileDetail" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/me/online": {
      "get": {
        "tags": ["Me"],
        "summary": "Get online status",
        "description": "Get the authenticated user's online status.",
        "security": [{ "SessionAuth": [] }],
        "responses": {
          "200": {
            "description": "Online status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "isOnline": { "type": "boolean" },
                    "lastSeen": { "type": "string", "format": "date-time", "nullable": true }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Me"],
        "summary": "Update online status",
        "description": "Set the authenticated user's online/offline status.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["isOnline"],
                "properties": {
                  "isOnline": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "integer" }, "isOnline": { "type": "boolean" }, "lastSeen": { "type": "string", "format": "date-time" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/me/notifications": {
      "get": {
        "tags": ["Me"],
        "summary": "Get my notifications",
        "description": "Retrieve paginated notifications for the authenticated user.",
        "security": [{ "SessionAuth": [] }],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "isRead", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by read status" }
        ],
        "responses": {
          "200": {
            "description": "Paginated notifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Notification" } },
                    "unreadCount": { "type": "integer" },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Me"],
        "summary": "Mark notifications as read",
        "description": "Mark specific or all notifications as read.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NotificationUpdateBody" } } }
        },
        "responses": {
          "200": {
            "description": "Notifications updated",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "unreadCount": { "type": "integer" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Me"],
        "summary": "Delete notifications",
        "description": "Delete specific notification or clear all.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "notificationId": { "type": "integer", "description": "ID of notification to delete" },
                  "clearAll": { "type": "boolean", "description": "Delete all notifications" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notifications deleted",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "unreadCount": { "type": "integer" } } } } }
          },
          "400": { "description": "Missing notificationId or clearAll", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/me/api-keys": {
      "get": {
        "tags": ["Me"],
        "summary": "List API keys",
        "description": "Get all API keys for the authenticated user.",
        "security": [{ "SessionAuth": [] }],
        "responses": {
          "200": {
            "description": "List of API keys",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ApiKey" } } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "tags": ["Me"],
        "summary": "Create API key",
        "description": "Generate a new API key for accessing the public API.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "My CLI Key" },
                  "expiresInDays": { "type": "integer", "example": 30, "description": "Optional expiration in days" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key created",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "data": { "$ref": "#/components/schemas/ApiKey" } } } } }
          },
          "400": { "description": "Missing name", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Me"],
        "summary": "Delete API key",
        "description": "Revoke and delete an API key.",
        "security": [{ "SessionAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "API key ID to delete" }
        ],
        "responses": {
          "200": {
            "description": "API key deleted",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } }
          },
          "400": { "description": "Invalid ID", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/profiles/update": {
      "put": {
        "tags": ["Profiles"],
        "summary": "Update profile (session)",
        "description": "Update the authenticated user's username and/or tank color.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "NewUsername" },
                  "tankColor": { "type": "string", "example": "#ff0000" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated", "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "user": { "$ref": "#/components/schemas/ProfileSummary" } } } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "Username already taken", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/profiles/avatar": {
      "post": {
        "tags": ["Profiles"],
        "summary": "Upload avatar",
        "description": "Upload a new avatar image for the authenticated user.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatar": { "type": "string", "format": "binary", "description": "Image file (jpg, png, gif, webp, max 5MB)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Avatar uploaded",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "avatarUrl": { "type": "string" } } } } }
          },
          "400": { "description": "No file or invalid type", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/friends/request": {
      "post": {
        "tags": ["Friends"],
        "summary": "Send friend request",
        "description": "Send a friend request to another user by username.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username"],
                "properties": {
                  "username": { "type": "string", "example": "TankPro" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Friend request sent", "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "integer" }, "status": { "type": "string" } } } } } },
          "400": { "description": "Already friends or request exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "User not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/friends/accept": {
      "post": {
        "tags": ["Friends"],
        "summary": "Accept friend request",
        "description": "Accept a pending friend request.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["friendshipId"],
                "properties": {
                  "friendshipId": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Friend request accepted", "content": { "application/json": { "schema": { "type": "object", "properties": { "friendship": { "type": "object" }, "conversation": { "type": "object" } } } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Request not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/friends/deny": {
      "post": {
        "tags": ["Friends"],
        "summary": "Deny friend request",
        "description": "Decline a pending friend request.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["friendshipId"],
                "properties": {
                  "friendshipId": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Friend request denied", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" } } } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Request not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/friends/delete": {
      "post": {
        "tags": ["Friends"],
        "summary": "Remove friend",
        "description": "Remove an existing friendship.",
        "security": [{ "SessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["friendId"],
                "properties": {
                  "friendId": { "type": "integer", "example": 2 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Friend removed", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" } } } } } },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Friendship not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
