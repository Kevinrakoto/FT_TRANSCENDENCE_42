    "/api/friends/search": {
      "get": {
        "tags": ["Friends"],
        "summary": "Search users",
        "description": "Search for users by username to send friend requests.",
        "security": [{ "SessionAuth": [] }],
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query (username)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "integer" },
                      "username": { "type": "string" },
                      "tankColor": { "type": "string" },
                      "isOnline": { "type": "boolean" }
                    }
                  }
                }
              }
